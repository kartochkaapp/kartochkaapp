{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "server/prompts/*.md"
        ]
      }
    },
    {
      "src": "!{api/**,package.json,middleware.[jt]s}",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/api/enhance-card",
      "destination": "/api/enhance-card.js"
    },
    {
      "source": "/api/kartochka/historyAsset/:id",
      "destination": "/api/kartochka/historyAsset.js?id=:id"
    },
    {
      "source": "/api/kartochka/:action",
      "destination": "/api/kartochka/:action.js"
    },
    {
      "source": "/app",
      "destination": "/index.html"
    },
    {
      "source": "/app/:mode(create|improve|tools|animate|history)",
      "destination": "/index.html"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "app\\..+"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/:mode(create|improve|tools|animate|history)",
      "has": [
        {
          "type": "host",
          "value": "app\\..+"
        }
      ],
      "destination": "/index.html"
    },
    {
      "source": "/",
      "missing": [
        {
          "type": "host",
          "value": "app\\..+"
        }
      ],
      "destination": "/public.html"
    }
  ]
}
