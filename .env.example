PORT=2020
HOST=0.0.0.0
# Local Node server base URL. For production examples use your canonical domain, e.g. https://<your-domain>.
PUBLIC_BASE_URL=http://localhost:2020
REQUEST_TIMEOUT_MS=300000
REQUEST_BODY_LIMIT_BYTES=26214400

OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_REASONING_EFFORT=medium

OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=google/gemini-3-pro-image-preview
OPENROUTER_TEXT_REPLACE_LOCATOR_MODEL=google/gemini-2.5-flash
OPENROUTER_TEXT_REPLACE_EDITOR_MODEL=google/gemini-2.5-flash-image-preview
# Production example: https://<your-domain>
OPENROUTER_REFERER=http://localhost:2020
OPENROUTER_TITLE=KARTOCHKA

BILLING_STARTER_TOKENS=12
BILLING_STORE_MODE=auto
# Built-in promo codes:
# - WELCOME50 -> 50 tokens, up to 5 times per account
# - START100 -> 100 tokens, 1 time per account
# Optional extra seeds example:
# BILLING_PROMO_SEEDS=[{"code":"SPRING25","tokens":25,"description":"Сезонный бонус","perUserLimit":1,"maxRedemptions":500}]
BILLING_PROMO_SEEDS=

# Production note: history is only production-safe with HISTORY_STORE_MODE=firestore
# and valid FIREBASE_ADMIN_* credentials. Serverless deployments no longer fall back
# to ephemeral local files for history persistence.
HISTORY_STORE_MODE=firestore
HISTORY_MAX_ITEMS=30

FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=
